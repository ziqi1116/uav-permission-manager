<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.FlightApplicationMapper">

    <resultMap type="com.ruoyi.system.domain.FlightApplication" id="FlightApplicationResult">
        <id     property="id"               column="id"                 />
        <result property="applicationNo"   column="application_no"   />
        <result property="applicantId"      column="applicant_id"     />
        <result property="droneId"         column="drone_id"          />
        <result property="flightArea"      column="flight_area"       />
        <result property="flightHeight"    column="flight_height"    />
        <result property="startTime"       column="start_time"       />
        <result property="endTime"         column="end_time"         />
        <result property="purpose"         column="purpose"          />
        <result property="status"           column="status"           />
        <result property="approveUser"     column="approve_user"     />
        <result property="approveTime"      column="approve_time"    />
        <result property="approveRemark"    column="approve_remark"   />
        <result property="secondApproveUser" column="second_approve_user" />
        <result property="secondApproveTime" column="second_approve_time" />
        <result property="createBy"        column="create_by"        />
        <result property="createTime"       column="create_time"     />
        <result property="updateBy"        column="update_by"        />
        <result property="updateTime"       column="update_time"     />
        <result property="remark"          column="remark"           />
        <result property="applicantName"   column="applicant_name"  />
        <result property="droneName"        column="drone_name"       />
        <result property="approveUserName"  column="approve_user_name" />
    </resultMap>

    <sql id="selectFlightApplicationVo">
        select a.id, a.application_no, a.applicant_id, a.drone_id, a.flight_area, a.flight_height,
               a.start_time, a.end_time, a.purpose, a.status, a.approve_user, a.approve_time, a.approve_remark,
               a.second_approve_user, a.second_approve_time, a.create_by, a.create_time, a.update_by, a.update_time, a.remark,
               u.nick_name as applicant_name,
               d.drone_name as drone_name,
               au.nick_name as approve_user_name
        from flight_application a
        left join sys_user u on a.applicant_id = u.user_id
        left join drone_info d on a.drone_id = d.id
        left join sys_user au on a.approve_user = au.user_id
    </sql>

    <select id="selectFlightApplicationById" parameterType="Long" resultMap="FlightApplicationResult">
        <include refid="selectFlightApplicationVo"/>
        where a.id = #{id}
    </select>

    <select id="selectFlightApplicationList" parameterType="com.ruoyi.system.domain.FlightApplication" resultMap="FlightApplicationResult">
        <include refid="selectFlightApplicationVo"/>
        <where>
            <if test="applicationNo != null and applicationNo != ''">
                AND a.application_no like concat('%', #{applicationNo}, '%')
            </if>
            <if test="applicantId != null">
                AND a.applicant_id = #{applicantId}
            </if>
            <if test="droneId != null">
                AND a.drone_id = #{droneId}
            </if>
            <if test="status != null and status != ''">
                AND a.status = #{status}
            </if>
            <if test="params.beginTime != null and params.beginTime != ''">
                AND date_format(a.create_time,'%Y%m%d') &gt;= date_format(#{params.beginTime},'%Y%m%d')
            </if>
            <if test="params.endTime != null and params.endTime != ''">
                AND date_format(a.create_time,'%Y%m%d') &lt;= date_format(#{params.endTime},'%Y%m%d')
            </if>
        </where>
    </select>

    <select id="selectByApplicationNo" parameterType="String" resultMap="FlightApplicationResult">
        <include refid="selectFlightApplicationVo"/>
        where a.application_no = #{applicationNo} limit 1
    </select>

    <insert id="insertFlightApplication" parameterType="com.ruoyi.system.domain.FlightApplication" useGeneratedKeys="true" keyProperty="id">
        insert into flight_application (
            application_no, applicant_id, drone_id, flight_area, flight_height, start_time, end_time,
            purpose, status, create_by, remark, create_time
        ) values (
            #{applicationNo}, #{applicantId}, #{droneId}, #{flightArea}, #{flightHeight}, #{startTime}, #{endTime},
            #{purpose}, #{status}, #{createBy}, #{remark}, sysdate()
        )
    </insert>

    <update id="updateFlightApplication" parameterType="com.ruoyi.system.domain.FlightApplication">
        update flight_application
        <set>
            <if test="flightArea != null and flightArea != ''">flight_area = #{flightArea},</if>
            <if test="flightHeight != null">flight_height = #{flightHeight},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="purpose != null">purpose = #{purpose},</if>
            <if test="status != null">status = #{status},</if>
            <if test="approveUser != null">approve_user = #{approveUser},</if>
            <if test="approveTime != null">approve_time = #{approveTime},</if>
            <if test="approveRemark != null">approve_remark = #{approveRemark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where id = #{id}
    </update>

    <delete id="deleteFlightApplicationById" parameterType="Long">
        delete from flight_application where id = #{id}
    </delete>

    <delete id="deleteFlightApplicationByIds" parameterType="Long">
        delete from flight_application where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
